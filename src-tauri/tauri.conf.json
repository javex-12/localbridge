{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "localbridge",
  "version": "0.1.0",
  "identifier": "com.localbridge.pro",
  "build": {
    "frontendDist": "../src",
    "devUrl": null,
    "beforeDevCommand": "echo dev",
    "beforeBuildCommand": "echo build"
  },
  "app": {
    "windows": [
      {
        "title": "LocalBridge",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
